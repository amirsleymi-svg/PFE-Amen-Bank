# Copy this file to `.env` and edit values for your environment.

# MySQL database (must point to same DB as Spring Boot)
DATABASE_URL=mysql+aiomysql://root:@localhost:3306/amen_bank

# JWT secret — MUST match backend/src/main/resources/application.yml jwt.secret
JWT_SECRET=aW1wb3J0YW50LXNlY3JldC1rZXktZm9yLWFtZW4tYmFuay1hcHBsaWNhdGlvbi0yMDI2LXNlY3VyZS1rZXktbXVzdC1iZS1sb25n

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
